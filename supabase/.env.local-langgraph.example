# Copy to supabase/.env.local-langgraph and fill OPENAI_API_KEY.
# This file is for the local simulator LangGraph proof only.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Supabase Edge Runtime runs in Docker during local function serving, so it
# reaches the host machine through host.docker.internal on macOS.
TRAINING_ORCHESTRATOR_URL=http://host.docker.internal:8787
TRAINING_ORCHESTRATOR_API_KEY=local-langgraph-dev
TRAINING_ORCHESTRATOR_REQUIRED=true
